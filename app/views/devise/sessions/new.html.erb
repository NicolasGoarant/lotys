<%= render "shared/navbar" %>

<%# Bloc vert mobile %>
<div class="lg-hide" style="background:linear-gradient(135deg,#059669,#065f46);padding:20px 20px 24px;">
  <p style="color:white;font-size:1.3rem;font-weight:900;line-height:1.25;margin:0 0 14px;">Votre bien mérite<br>une analyse complète.</p>
  <div style="display:flex;flex-direction:column;gap:8px;">
    <% [
      ["🏷️", "Estimation DVF en temps réel", "Vraies transactions du marché"],
      ["💰", "Simulation des aides", "Éco-PTZ, MaPrimeRénov', CEE"],
      ["🤝", "Enchères inversées", "Les prestataires viennent à vous"],
    ].each do |emoji, title, desc| %>
      <div style="display:flex;align-items:center;gap:10px;background:rgba(255,255,255,0.12);border-radius:10px;padding:10px 14px;">
        <span style="font-size:1.1rem;"><%= emoji %></span>
        <div>
          <p style="color:white;font-weight:700;font-size:0.8rem;margin:0;"><%= title %></p>
          <p style="color:#6ee7b7;font-size:0.72rem;margin:1px 0 0;"><%= desc %></p>
        </div>
      </div>
    <% end %>
  </div>
  <div style="background:rgba(255,255,255,0.1);border-radius:10px;padding:12px 14px;margin-top:12px;border:1px solid rgba(255,255,255,0.2);">
    <p style="color:white;font-size:0.78rem;font-style:italic;line-height:1.5;margin:0;">"En 10 minutes, j'ai compris que la vente en bloc valait 40 000€ de plus."</p>
    <p style="color:#6ee7b7;font-size:0.7rem;margin:6px 0 0;font-weight:600;">— Nicolas G., Nancy</p>
  </div>
</div>

<%# Layout 2 colonnes desktop %>
<div style="display:flex;min-height:calc(100vh - 60px);">

  <%# Colonne verte desktop %>
  <div class="lg-show" style="display:none;width:50%;background:linear-gradient(135deg,#059669,#065f46);flex-direction:column;justify-content:center;padding:4rem;position:relative;overflow:hidden;">
    <div style="position:absolute;inset:0;background-image:url('https://images.unsplash.com/photo-1560518883-ce09059eeffa?w=900&q=80');background-size:cover;background-position:center;opacity:0.12;"></div>
    <div style="position:relative;z-index:10;">
      <p style="color:white;font-size:2.25rem;font-weight:900;line-height:1.2;margin-bottom:2rem;">Votre bien mérite<br>une analyse complète.</p>
      <% [
        ["🏷️", "Estimation DVF en temps réel", "Basée sur les vraies transactions du marché"],
        ["💰", "Simulation des aides", "Éco-PTZ, MaPrimeRénov', CEE cumulés"],
        ["🤝", "Enchères inversées", "Les prestataires viennent à vous"],
      ].each do |emoji, title, desc| %>
        <div style="display:flex;gap:12px;margin-bottom:1.25rem;">
          <span style="font-size:1.5rem;line-height:1;margin-top:2px;"><%= emoji %></span>
          <div>
            <p style="color:white;font-weight:600;margin:0;"><%= title %></p>
            <p style="color:#6ee7b7;font-size:0.875rem;margin:2px 0 0;"><%= desc %></p>
          </div>
        </div>
      <% end %>
      <div style="background:rgba(255,255,255,0.1);border-radius:1rem;padding:1.25rem;border:1px solid rgba(255,255,255,0.2);margin-top:2rem;">
        <p style="color:white;font-size:0.875rem;font-style:italic;line-height:1.6;margin:0;">"En 10 minutes, j'ai compris que la vente en bloc avec mes voisins valait 40 000€ de plus qu'une vente classique."</p>
        <p style="color:#6ee7b7;font-size:0.75rem;margin:10px 0 0;font-weight:600;">— Nicolas G., Nancy</p>
      </div>
    </div>
  </div>

  <%# Colonne formulaire %>
  <div style="flex:1;display:flex;align-items:flex-start;justify-content:center;background:#f9fafb;padding:1.5rem 1.5rem;">
    <div style="width:100%;max-width:380px;">

      <h1 style="font-size:1.75rem;font-weight:900;color:#111827;margin:0 0 4px;">Connexion</h1>
      <p style="color:#6b7280;font-size:0.875rem;margin:0 0 1.75rem;">
        Pas encore de compte ?
        <%= link_to "S'inscrire →", new_user_registration_path, style: "color:#059669;font-weight:600;text-decoration:none;" %>
      </p>

      <% if alert %>
        <div style="background:#fef2f2;border:1px solid #fecaca;color:#dc2626;border-radius:0.75rem;padding:12px 16px;font-size:0.875rem;margin-bottom:1.25rem;">
          <%= alert %>
        </div>
      <% end %>

      <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
        <div style="margin-bottom:1rem;">
          <%= f.label :email, "Email", style: "display:block;font-size:0.875rem;font-weight:600;color:#374151;margin-bottom:6px;" %>
          <%= f.email_field :email, autofocus: true, autocomplete: "email",
              style: "width:100%;padding:12px 16px;border-radius:12px;border:1px solid #e5e7eb;background:white;font-size:0.875rem;box-sizing:border-box;",
              placeholder: "vous@exemple.fr" %>
        </div>
        <div style="margin-bottom:1rem;">
          <%= f.label :password, "Mot de passe", style: "display:block;font-size:0.875rem;font-weight:600;color:#374151;margin-bottom:6px;" %>
          <%= f.password_field :password, autocomplete: "current-password",
              style: "width:100%;padding:12px 16px;border-radius:12px;border:1px solid #e5e7eb;background:white;font-size:0.875rem;box-sizing:border-box;",
              placeholder: "••••••••" %>
        </div>
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:1.25rem;">
          <label style="display:flex;align-items:center;gap:8px;font-size:0.875rem;color:#6b7280;cursor:pointer;">
            <%= f.check_box :remember_me, style: "width:16px;height:16px;" %>
            Se souvenir de moi
          </label>
          <%= link_to "Mot de passe oublié ?", new_user_password_path, style: "font-size:0.875rem;color:#059669;text-decoration:none;" %>
        </div>
        <%= f.submit "Se connecter →",
            style: "width:100%;background:#059669;color:white;font-weight:700;padding:14px;border-radius:12px;border:none;font-size:0.9375rem;cursor:pointer;" %>
      <% end %>

      <div style="display:flex;align-items:center;gap:12px;margin:1.25rem 0;">
        <div style="flex:1;height:1px;background:#e5e7eb;"></div>
        <span style="font-size:0.75rem;color:#9ca3af;">ou</span>
        <div style="flex:1;height:1px;background:#e5e7eb;"></div>
      </div>

      <%= link_to new_property_path,
          style: "display:flex;align-items:center;justify-content:center;gap:8px;border:1px solid #e5e7eb;background:white;color:#374151;font-weight:500;padding:13px;border-radius:12px;text-decoration:none;font-size:0.875rem;" do %>
        🏠 Analyser mon bien sans compte
      <% end %>

    </div>
  </div>
</div>

<style>
  @media (min-width: 1024px) {
    .lg-show { display: flex !important; }
    .lg-hide { display: none !important; }
  }
</style>
