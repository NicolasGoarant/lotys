<div id="<%= dom_id offer %>" class="w-full sm:w-auto my-5 space-y-5">
  <div>
    <strong class="block font-medium mb-1">Property:</strong>
    <%= offer.property_id %>
  </div>
  <div>
    <strong class="block font-medium mb-1">User:</strong>
    <%= offer.user_id %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Offer type:</strong>
    <%= offer.offer_type %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Amount:</strong>
    <%= offer.amount %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Description:</strong>
    <%= offer.description %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Status:</strong>
    <%= offer.status %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Expires at:</strong>
    <%= offer.expires_at %>
  </div>
</div>
