<%# Hero plein écran %>
<div class="full-bleed relative -mt-8" style="height: 85vh; min-height: 560px;">
  <img src="https://images.unsplash.com/photo-1570129477492-45c003edd2be?w=1600&q=80"
       alt="Maison française" class="absolute inset-0 w-full h-full object-cover">
  <div class="absolute inset-0 bg-gradient-to-b from-gray-900/60 via-gray-900/55 to-gray-900/85"></div>

  <div class="relative h-full flex flex-col items-center justify-center text-center px-6">
    <span class="inline-block bg-white/20 backdrop-blur text-white text-xs font-semibold px-3 py-1 rounded-full mb-6 uppercase tracking-wide border border-white/30">
      Prototype Nancy — V1
    </span>

    <h1 class="text-5xl md:text-7xl font-bold text-white mb-8 leading-tight"
        style="text-shadow: 0 2px 20px rgba(0,0,0,0.8);">
      L'immobilier,<br>enfin lisible.
    </h1>

    <%# Phrases empilées avec émojis %>
    <div class="flex flex-col gap-2 mb-6" style="text-shadow: 0 2px 12px rgba(0,0,0,0.9);">
      <p class="text-lg md:text-xl text-white font-semibold">🏠 Vous avez un bien.</p>
      <p class="text-lg md:text-xl text-white font-semibold">📂 Vous avez des documents — beaucoup.</p>
      <p class="text-lg md:text-xl text-white font-semibold">❓ Vous avez des questions.</p>
    </div>

    <%# Réponse Lotys — mise en valeur %>
    <div class="bg-emerald-600/80 backdrop-blur border border-emerald-400/50 rounded-2xl px-8 py-4 mb-10 max-w-xl">
      <p class="text-white font-bold text-lg md:text-xl leading-snug"
         style="text-shadow: 0 1px 6px rgba(0,0,0,0.5);">
        Lotys lit tout, analyse tout,<br>
        et vous dit quoi faire :
        <span class="text-emerald-200">rénover · vendre · vendre en bloc.</span>
      </p>
    </div>

    <div class="flex flex-col sm:flex-row justify-center gap-4">
      <%= link_to "Analyser mon bien gratuitement", new_property_path,
          class: "bg-emerald-500 text-white px-10 py-4 rounded-2xl hover:bg-emerald-400 font-bold text-lg shadow-xl transition" %>
      <%= link_to "Comment ça marche →", about_path,
          class: "bg-white/15 backdrop-blur border border-white/40 text-white px-10 py-4 rounded-2xl hover:bg-white/25 font-semibold text-lg transition" %>
    </div>

    <div class="absolute bottom-8 flex flex-col items-center text-white/50 text-xs gap-1">
      <span>Découvrir</span>
      <svg class="w-4 h-4 animate-bounce" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
      </svg>
    </div>
  </div>
</div>

<%# 3 fonctionnalités %>
<div class="grid grid-cols-1 md:grid-cols-3 gap-4 mt-16 mb-16">
  <div class="bg-white border border-gray-100 rounded-2xl p-6 shadow-sm">
    <div class="text-4xl mb-3">🏠</div>
    <h3 class="font-bold text-gray-800 text-lg mb-2">Estimation de valeur</h3>
    <p class="text-gray-500 text-sm leading-relaxed">Basée sur les ventes réelles de votre secteur (DVF), avec bonus vente en bloc pour les copropriétés.</p>
  </div>
  <div class="bg-white border border-gray-100 rounded-2xl p-6 shadow-sm">
    <div class="text-4xl mb-3">⚡</div>
    <h3 class="font-bold text-gray-800 text-lg mb-2">Aides à la rénovation</h3>
    <p class="text-gray-500 text-sm leading-relaxed">Éco-PTZ, MaPrimeRénov', CEE — calculés automatiquement depuis vos documents.</p>
  </div>
  <div class="bg-white border border-gray-100 rounded-2xl p-6 shadow-sm">
    <div class="text-4xl mb-3">🤝</div>
    <h3 class="font-bold text-gray-800 text-lg mb-2">Enchère inversée</h3>
    <p class="text-gray-500 text-sm leading-relaxed">Publiez votre besoin, recevez des propositions d'artisans, banquiers et promoteurs.</p>
  </div>
</div>

<%# Bandeau CTA %>
<div class="bg-emerald-600 rounded-2xl p-8 md:p-10 text-center text-white mb-8">
  <p class="text-xl md:text-2xl font-bold mb-2">Quelle est la valeur réelle de votre bien ?</p>
  <p class="text-emerald-100 mb-6 text-sm md:text-base">Téléchargez vos documents en 2 minutes et obtenez une analyse complète.</p>
  <%= link_to "Analyser mon bien →", new_property_path,
      class: "inline-block bg-white text-emerald-700 font-semibold px-6 py-3 rounded-xl hover:bg-emerald-50 transition" %>
</div>
