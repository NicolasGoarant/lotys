<div class="max-w-2xl mx-auto">

  <%# Détection source institutionnelle %>
  <% source = params[:source] %>
  <% is_brigade = source == "brigade_nancy" %>

  <%# Header — adapté selon la source %>
  <% if is_brigade %>
    <div style="background:linear-gradient(135deg,#1e3a5f,#1e40af);border-radius:1.5rem;padding:1.5rem 2rem;margin-bottom:2rem;color:white;">
      <p style="font-size:0.7rem;font-weight:700;letter-spacing:0.1em;color:#93c5fd;margin:0 0 6px;">VILLE DE NANCY · BRIGADE LOGEMENTS VACANTS</p>
      <h1 style="font-size:1.5rem;font-weight:900;margin:0 0 8px;">Vous avez reçu un courrier de la Ville de Nancy</h1>
      <p style="font-size:0.875rem;color:#bfdbfe;margin:0;line-height:1.6;">
        Lotys est l'outil partenaire de la Ville pour vous aider à comprendre les options pour votre logement — valeur, aides, scénarios. Gratuit, sans engagement, confidentiel.
      </p>
    </div>
  <% else %>
    <div class="text-center mb-10">
      <h1 class="text-4xl font-bold text-gray-900 mb-3">Analysez votre bien</h1>
      <p class="text-gray-500 text-lg">Deux informations suffisent. Lotys fait le reste.</p>
    </div>
  <% end %>

  <%= form_with model: @property, multipart: true, data: { turbo: false }, class: "space-y-6" do |f| %>
    <%= f.hidden_field :source, value: source %>

    <% if @property.errors.any? %>
      <div class="bg-red-50 border border-red-200 rounded-2xl p-5 text-sm text-red-700">
        <% @property.errors.full_messages.each do |msg| %>
          <p>⚠️ <%= msg %></p>
        <% end %>
      </div>
    <% end %>

    <%# Bloc 0 — Statut d'occupation (NOUVEAU) %>
    <div class="bg-white border border-gray-100 rounded-3xl p-8 shadow-sm">
      <div class="flex items-center gap-3 mb-6">
        <span class="text-3xl">🏠</span>
        <div>
          <h2 class="text-xl font-bold text-gray-800">Votre logement est-il occupé ?</h2>
          <p class="text-sm text-gray-400">Cela oriente les recommandations de Lotys.</p>
        </div>
      </div>

      <div class="grid grid-cols-2 gap-4 mb-6" id="occupation-choice">
        <label id="label-occupe"
               onclick="setOccupation(false)"
               style="cursor:pointer;border:2px solid #e5e7eb;border-radius:1rem;padding:1.25rem;text-align:center;transition:all 0.15s;">
          <input type="radio" name="occupation_radio" value="false" class="hidden">
          <div style="font-size:2rem;margin-bottom:8px;">👥</div>
          <p style="font-weight:700;color:#111827;margin:0 0 4px;">Oui, il est occupé</p>
          <p style="font-size:0.75rem;color:#6b7280;margin:0;">Par moi, un locataire ou de la famille</p>
        </label>
        <label id="label-vacant"
               onclick="setOccupation(true)"
               style="cursor:pointer;border:2px solid #e5e7eb;border-radius:1rem;padding:1.25rem;text-align:center;transition:all 0.15s;">
          <input type="radio" name="occupation_radio" value="true" class="hidden">
          <div style="font-size:2rem;margin-bottom:8px;">🔑</div>
          <p style="font-weight:700;color:#111827;margin:0 0 4px;">Non, il est inoccupé</p>
          <p style="font-size:0.75rem;color:#6b7280;margin:0;">Vacant, en succession, ou en attente</p>
        </label>
      </div>
      <%= f.hidden_field :vacant, value: false, id: "vacant-field" %>

      <%# Questions complémentaires si vacant %>
      <div id="vacant-questions" style="display:none;background:#fafafa;border-radius:1rem;padding:1.25rem;border:1px solid #f3f4f6;">
        <p class="text-sm font-semibold text-gray-700 mb-4">Quelques précisions pour affiner l'analyse :</p>
        <div class="space-y-4">
          <div>
            <label class="block text-sm font-medium text-gray-600 mb-2">Depuis combien de temps ce logement est-il inoccupé ?</label>
            <div class="grid grid-cols-2 gap-2">
              <% [
                ["moins_1an", "Moins d'un an"],
                ["1_2ans",    "1 à 2 ans"],
                ["2_5ans",    "2 à 5 ans"],
                ["plus_5ans", "Plus de 5 ans"],
              ].each do |val, label| %>
                <label style="cursor:pointer;border:1px solid #e5e7eb;border-radius:0.75rem;padding:10px 12px;font-size:0.8rem;display:flex;align-items:center;gap:8px;background:white;">
                  <%= f.radio_button :vacancy_duration, val, style: "accent-color:#059669;" %>
                  <%= label %>
                </label>
              <% end %>
            </div>
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-600 mb-2">Quelle en est la raison principale ?</label>
            <div class="grid grid-cols-2 gap-2">
              <% [
                ["succession",  "Succession / héritage"],
                ["travaux",     "Travaux nécessaires"],
                ["attente",     "En attente de décision"],
                ["autre",       "Autre raison"],
              ].each do |val, label| %>
                <label style="cursor:pointer;border:1px solid #e5e7eb;border-radius:0.75rem;padding:10px 12px;font-size:0.8rem;display:flex;align-items:center;gap:8px;background:white;">
                  <%= f.radio_button :vacancy_reason, val, style: "accent-color:#059669;" %>
                  <%= label %>
                </label>
              <% end %>
            </div>
          </div>
        </div>
      </div>
    </div>

    <%# Bloc 1 — Adresse %>
    <div class="bg-white border border-gray-100 rounded-3xl p-8 shadow-sm">
      <div class="flex items-center gap-3 mb-6">
        <span class="text-3xl">📍</span>
        <div>
          <h2 class="text-xl font-bold text-gray-800">Adresse du bien</h2>
          <p class="text-sm text-gray-400">C'est la seule information que nous vous demandons.</p>
        </div>
      </div>
      <div class="space-y-4">
        <%= f.text_field :address, placeholder: "12 rue de la Paix",
            class: "w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-emerald-400 bg-gray-50" %>
        <div class="grid grid-cols-2 gap-4">
          <%= f.text_field :city, placeholder: "Nancy",
              class: "w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-emerald-400 bg-gray-50" %>
          <%= f.text_field :zipcode, placeholder: "54000",
              class: "w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-emerald-400 bg-gray-50" %>
        </div>
      </div>
    </div>

    <%# Bloc 2 — Documents %>
    <div class="bg-white border border-gray-100 rounded-3xl p-8 shadow-sm">
      <div class="flex items-center gap-3 mb-2">
        <span class="text-3xl">📎</span>
        <div>
          <h2 class="text-xl font-bold text-gray-800">Vos documents et photos</h2>
          <p class="text-sm text-gray-400">Lotys analyse tout automatiquement — aucune saisie manuelle.</p>
        </div>
      </div>
      <div class="grid grid-cols-2 gap-3 my-6">
        <div class="bg-emerald-50 rounded-2xl p-4 text-sm">
          <p class="font-semibold text-emerald-800 mb-2">📋 Ce que Lotys lit dans vos docs</p>
          <ul class="text-emerald-700 space-y-1 text-xs">
            <li>✓ Classe énergétique (DPE)</li>
            <li>✓ Surface et année de construction</li>
            <li>✓ Situation de la copropriété</li>
            <li>✓ Alertes juridiques (titre de propriété)</li>
            <li>✓ Ambiance de la copropriété (PV d'AG)</li>
          </ul>
        </div>
        <div class="bg-blue-50 rounded-2xl p-4 text-sm">
          <p class="font-semibold text-blue-800 mb-2">📸 Ce que Lotys voit sur vos photos</p>
          <ul class="text-blue-700 space-y-1 text-xs">
            <li>✓ État général du bien</li>
            <li>✓ Type de menuiseries</li>
            <li>✓ État de la toiture / façade</li>
            <li>✓ Travaux visibles à prévoir</li>
          </ul>
        </div>
      </div>
      <div class="border-2 border-dashed border-gray-200 rounded-2xl p-10 text-center hover:border-emerald-400 hover:bg-emerald-50 transition cursor-pointer"
           onclick="document.getElementById('documents_upload').click()">
        <div class="text-5xl mb-3">☁️</div>
        <p class="font-semibold text-gray-700 mb-1">Glissez tous vos fichiers ici</p>
        <p class="text-sm text-gray-400 mb-4">DPE · titre de propriété · PV d'AG · devis · photos</p>
        <span class="inline-block bg-emerald-600 text-white text-sm px-6 py-2 rounded-xl hover:bg-emerald-700">
          Parcourir les fichiers
        </span>
        <input type="file" id="documents_upload" name="property[uploaded_files][]"
               multiple accept=".pdf,.jpg,.jpeg,.png"
               class="hidden"
               onchange="showFileList(this)">
      </div>
      <p class="text-xs text-gray-400 text-center mt-3">PDF, JPG, PNG · Pas de limite · Max 10 Mo par fichier</p>
      <div id="file-list" class="mt-4 space-y-2 hidden"></div>
    </div>

    <%# Bloc 3 — Contexte libre %>
    <div class="bg-white border border-gray-100 rounded-3xl p-8 shadow-sm">
      <div class="flex items-center gap-3 mb-4">
        <span class="text-3xl">💬</span>
        <div>
          <h2 class="text-xl font-bold text-gray-800">Votre situation <span class="text-gray-400 font-normal text-base">(optionnel)</span></h2>
          <p class="text-sm text-gray-400" id="description-hint">Un contexte que vous souhaitez partager avec Lotys.</p>
        </div>
      </div>
      <%= f.text_area :description,
          placeholder: "Ex : j'ai hérité de ce bien, je souhaite évaluer s'il vaut mieux rénover ou vendre. Les relations en copropriété sont tendues.",
          rows: 3,
          id: "description-field",
          class: "w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-emerald-400 bg-gray-50 resize-none" %>
    </div>

    <%# CTA %>
    <div class="text-center pb-8">
      <%= f.submit "Lancer l'analyse →",
          class: "bg-emerald-600 text-white px-12 py-4 rounded-2xl hover:bg-emerald-700 font-bold text-xl shadow-md cursor-pointer transition" %>
      <p class="text-xs text-gray-400 mt-3">Sans engagement · Résultat en quelques minutes · Vos documents restent confidentiels</p>
    </div>
  <% end %>
</div>

<script>
function setOccupation(isVacant) {
  document.getElementById('vacant-field').value = isVacant;

  const labelOccupe = document.getElementById('label-occupe');
  const labelVacant = document.getElementById('label-vacant');
  const vacantQ     = document.getElementById('vacant-questions');
  const hint        = document.getElementById('description-hint');
  const desc        = document.getElementById('description-field');

  if (isVacant) {
    labelVacant.style.border = '2px solid #059669';
    labelVacant.style.background = '#f0fdf4';
    labelOccupe.style.border = '2px solid #e5e7eb';
    labelOccupe.style.background = 'white';
    vacantQ.style.display = 'block';
    hint.textContent = 'Ajoutez tout ce qui peut aider Lotys à mieux comprendre la situation de ce logement.';
    desc.placeholder = 'Ex : appartement hérité de ma mère en 2022, en mauvais état. Trois héritiers, décision à prendre ensemble. Personne ne souhaite le conserver.';
  } else {
    labelOccupe.style.border = '2px solid #059669';
    labelOccupe.style.background = '#f0fdf4';
    labelVacant.style.border = '2px solid #e5e7eb';
    labelVacant.style.background = 'white';
    vacantQ.style.display = 'none';
    hint.textContent = 'Un contexte que vous souhaitez partager avec Lotys.';
    desc.placeholder = "Ex : j'ai hérité de ce bien, je souhaite évaluer s'il vaut mieux rénover ou vendre. Les relations en copropriété sont tendues.";
  }
}

// Pré-sélectionner "vacant" si source brigade
<% if is_brigade %>
  document.addEventListener('DOMContentLoaded', () => setOccupation(true));
<% end %>

function showFileList(input) {
  const list = document.getElementById('file-list');
  list.innerHTML = '<p class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-2">Fichiers sélectionnés (' + input.files.length + ')</p>';
  list.classList.remove('hidden');
  Array.from(input.files).forEach(file => {
    const ext  = file.name.split('.').pop().toLowerCase();
    const icon = ['jpg','jpeg','png'].includes(ext) ? '📸' : '📄';
    const size = (file.size / 1024).toFixed(0) + ' Ko';
    list.innerHTML += `<div class="flex items-center justify-between bg-gray-50 rounded-xl px-4 py-2 text-sm">
      <span class="text-gray-700">${icon} ${file.name}</span>
      <span class="text-gray-400 text-xs">${size}</span>
    </div>`;
  });
}
</script>
<script>
document.querySelector("form").addEventListener("submit", function() {
  window.scrollTo(0,0); document.getElementById("loading-overlay").style.display = "flex";
  document.body.style.overflow = "hidden";
});
</script>

<div id="loading-overlay" style="display:none; position:fixed; top:57px; left:0; right:0; bottom:0; background:#f9fafb; z-index:40; flex-direction:column; align-items:center; justify-content:center;">
  <div style="text-align:center; max-width:380px; padding:0 24px;">
    <div style="font-size:3rem; margin-bottom:1.5rem;">⏳</div>
    <h2 style="font-size:1.5rem; font-weight:700; color:#111827; margin-bottom:0.5rem;">Analyse en cours…</h2>
    <p style="color:#6b7280; font-size:0.875rem; margin-bottom:2rem; line-height:1.6;">Notre IA lit vos documents et génère<br>votre rapport patrimonial complet.<br><strong>Cela prend 1 à 3 minutes</strong>, merci de patienter.</p>
    <div style="width:100%; background:#e5e7eb; border-radius:9999px; height:8px; overflow:hidden; margin-bottom:1rem;">
      <div id="progress-bar" style="height:8px; background:#10b981; border-radius:9999px; width:0%; animation:loading 120s ease-in-out forwards;"></div>
    </div>
    <p style="font-size:0.75rem; color:#9ca3af;">🔒 Vos documents restent confidentiels</p>
  </div>
</div>

<style>
@keyframes loading {
  0%   { width: 0% }
  20%  { width: 25% }
  40%  { width: 45% }
  65%  { width: 65% }
  85%  { width: 82% }
  100% { width: 94% }
}
</style>
