      </div>
      <div style="background:rgba(16,185,129,0.2);border:1px solid rgba(16,185,129,0.4);border-radius:1rem;padding:1rem;text-align:center;">
        <p style="font-size:0.7rem;color:#6ee7b7;margin:0 0 4px;">Aides mobilisables</p>
        <p style="font-size:1.25rem;font-weight:900;margin:0;color:#6ee7b7;">− <%= number_to_currency(sim.total_aid_estimate, unit: "€", format: "%n %u", precision: 0) %></p>
      </div>
      <div style="background:rgba(251,191,36,0.15);border:1px solid rgba(251,191,36,0.3);border-radius:1rem;padding:1rem;text-align:center;">
        <p style="font-size:0.7rem;color:#fde68a;margin:0 0 4px;">Reste à financer</p>
