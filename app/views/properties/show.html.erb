      <button onclick="setProfil(2)" class="profil-btn px-3 py-2 rounded-lg text-sm font-bold border-2 border-gray-200 text-gray-600 transition-colors text-left">Intermédiaires<br><span class="font-normal text-xs">30 000 – 45 000€</span></button>
      <button onclick="setProfil(3)" class="profil-btn px-3 py-2 rounded-lg text-sm font-bold border-2 border-gray-200 text-gray-600 transition-colors text-left">Supérieurs<br><span class="font-normal text-xs">&gt; 45 000€</span></button>
    </div>
  </div>
  <div class="space-y-2 mb-4">
    <div class="flex items-center justify-between bg-blue-50 rounded-xl px-4 py-3">
      <div><p class="font-bold text-blue-900 text-sm">Éco-PTZ</p><p class="text-xs text-blue-700">Prêt à 0% · Sans condition de ressources</p></div>
      <p class="font-black text-blue-900 text-base">jusqu'à 50 000 €</p>
    </div>
    <div class="flex items-center justify-between bg-purple-50 rounded-xl px-4 py-3">
      <div><p class="font-bold text-purple-900 text-sm">MaPrimeRénov'</p><p class="text-xs text-purple-700" id="aide-mpr-label">Sélectionnez votre profil de revenus</p></div>
      <p class="font-black text-purple-900 text-base" id="aide-mpr">—</p>
    </div>
    <div class="flex items-center justify-between bg-amber-50 rounded-xl px-4 py-3">
      <div><p class="font-bold text-amber-900 text-sm">CEE (Certificats Économies Énergie)</p><p class="text-xs text-amber-700">Via artisan RGE · Variable selon les travaux</p></div>
      <p class="font-black text-amber-900 text-base" id="aide-cee">—</p>
    </div>
  </div>
  <div class="flex items-center justify-between rounded-xl px-5 py-4 text-white mb-2" style="background:#1d4ed8;">
    <div><p class="font-bold text-base">Reste à financer</p><p class="text-blue-200 text-sm">Budget sélectionné – aides estimées</p></div>
    <p class="font-black text-xl" id="reste-financer">—</p>
  </div>
  <p class="text-xs text-gray-400 mb-6">⚠️ Estimations indicatives 2025. MaPrimeRénov' peut nécessiter un audit énergétique pour les rénovations globales.</p>
</div>
<div class="border-t border-gray-100 pt-6">
  <h3 class="font-bold text-gray-900 text-base mb-4">🏦 Simulateur de financement travaux</h3>

          <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-5">
            <div>
              <label class="text-xs font-bold text-gray-600 uppercase tracking-wide mb-1 block">Montant emprunté</label>
              <input type="range" id="sim-montant" min="5000" max="100000" step="1000" value="<%= e['budget_total_min'] || 30000 %>" class="w-full accent-emerald-600" oninput="calcPret()">
              <p class="text-right text-sm font-bold text-gray-900 mt-1" id="sim-montant-label">—</p>
            </div>
            <div>
              <label class="text-xs font-bold text-gray-600 uppercase tracking-wide mb-1 block">Durée</label>
              <input type="range" id="sim-duree" min="5" max="25" step="1" value="15" class="w-full accent-emerald-600" oninput="calcPret()">
              <p class="text-right text-sm font-bold text-gray-900 mt-1" id="sim-duree-label">—</p>
            </div>
            <div>
              <label class="text-xs font-bold text-gray-600 uppercase tracking-wide mb-1 block">Taux annuel</label>
              <input type="range" id="sim-taux" min="0" max="6" step="0.1" value="3.5" class="w-full accent-emerald-600" oninput="calcPret()">
              <p class="text-right text-sm font-bold text-gray-900 mt-1" id="sim-taux-label">—</p>
            </div>
          </div>
          <div style="display:grid; grid-template-columns:1fr; gap:0.75rem;" class="sim-results-grid">
            <div class="bg-emerald-50 border border-emerald-200 rounded-xl p-4 text-center">
              <p class="text-xs text-emerald-700 font-bold uppercase tracking-wide mb-1">Mensualité</p>
              <p class="text-2xl font-black text-emerald-800" id="sim-mensualite">—</p>
            </div>
            <div class="bg-gray-50 border border-gray-200 rounded-xl p-4 text-center">
              <p class="text-xs text-gray-600 font-bold uppercase tracking-wide mb-1">Coût total</p>
              <p class="text-2xl font-black text-gray-900" id="sim-cout-total">—</p>
            </div>
            <div class="bg-orange-50 border border-orange-200 rounded-xl p-4 text-center">
              <p class="text-xs text-orange-700 font-bold uppercase tracking-wide mb-1">Coût des intérêts</p>
              <p class="text-2xl font-black text-orange-800" id="sim-interets">—</p>
            </div>
          </div>
          <p class="text-xs text-gray-400 mt-3">💡 Simulation indicative hors assurance. Pour l'Éco-PTZ (taux 0%), réglez le curseur sur 0%.</p>
        </div>
      </div>
    </div>
    <script>
    function calcPret() {
      var M = parseInt(document.getElementById('sim-montant').value);
      var D = parseInt(document.getElementById('sim-duree').value);
      var T = parseFloat(document.getElementById('sim-taux').value);
      document.getElementById('sim-montant-label').textContent = M.toLocaleString('fr-FR') + ' €';
      document.getElementById('sim-duree-label').textContent = D + ' ans';
      document.getElementById('sim-taux-label').textContent = T.toFixed(1) + ' %';
      var n = D * 12;
      var fmt = function(x){ return Math.round(x).toLocaleString('fr-FR') + ' €'; };
      if (T === 0) {
        var mens = M / n;
        document.getElementById('sim-mensualite').textContent = fmt(mens) + '/mois';
        document.getElementById('sim-cout-total').textContent = fmt(M);
        document.getElementById('sim-interets').textContent = '0 €';
      } else {
        var r = (T / 100) / 12;
        var mens = M * r * Math.pow(1+r,n) / (Math.pow(1+r,n)-1);
        var total = mens * n;
        document.getElementById('sim-mensualite').textContent = fmt(mens) + '/mois';
        document.getElementById('sim-cout-total').textContent = fmt(total);
        document.getElementById('sim-interets').textContent = fmt(total - M);
      }
    }
document.addEventListener('DOMContentLoaded', calcPret);

var currentProfil = -1;
document.addEventListener('DOMContentLoaded', calcPret);
var currentProfil = -1;
var mprTaux = [0.70, 0.50, 0.35, 0.15];
var mprLabels = ['Bleu - 70% max', 'Jaune - 50% max', 'Violet - 35% max', 'Rose - 15% max'];
function setProfil(p) {
  currentProfil = p;
  document.querySelectorAll('.profil-btn').forEach(function(b, i) {
    b.style.borderColor = i === p ? '#059669' : '';
    b.style.color = i === p ? '#047857' : '';
    b.style.background = i === p ? '#ecfdf5' : '';
  });
  calcAides();
}
function calcAides() {
  var cbs = document.querySelectorAll('.travaux-cb');
  var maxBudget = 0;
  cbs.forEach(function(cb) { if (cb.checked) maxBudget += parseInt(cb.dataset.max) || 0; });
  var cee = maxBudget > 0 ? Math.min(Math.round(maxBudget * 0.08), 4000) : 0;
  document.getElementById('aide-cee').textContent = cee > 0 ? cee.toLocaleString('fr-FR') + ' €' : '—';
  var mpr = 0;
  if (currentProfil >= 0 && maxBudget > 0) {
    mpr = Math.min(Math.round(maxBudget * mprTaux[currentProfil]), 20000);
    document.getElementById('aide-mpr').textContent = mpr.toLocaleString('fr-FR') + ' €';
    document.getElementById('aide-mpr-label').textContent = mprLabels[currentProfil];
  } else {
    document.getElementById('aide-mpr').textContent = '—';
    document.getElementById('aide-mpr-label').textContent = 'Sélectionnez votre profil';
  }
  var totalAides = (currentProfil >= 0 ? mpr : 0) + cee;
  var reste = Math.max(0, maxBudget - totalAides);
  document.getElementById('reste-financer').textContent = reste > 0 ? reste.toLocaleString('fr-FR') + ' €' : maxBudget > 0 ? '0 €' : '—';
  var slider = document.getElementById('sim-montant');
  if (slider && reste > 0) { slider.value = reste; calcPret(); }
}
document.addEventListener('DOMContentLoaded', function() { calcTravaux(); calcPret(); calcAides(); });
    </script>
    <% end %>

