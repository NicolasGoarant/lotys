          </ul>
        <% end %>
      </div>
    </div>
    <% end %>

    <% e = parsed["energie"] %>
    <% if e %>
    <% dpe_hex2 = {"A"=>"#16a34a","B"=>"#22c55e","C"=>"#84cc16","D"=>"#eab308","E"=>"#f97316","F"=>"#ea580c","G"=>"#dc2626"} %>
    <div class="rounded-2xl overflow-hidden mb-8 bg-white" style="border:2px solid #e2e8f0; border-top:4px solid #ea580c; box-shadow:0 4px 16px rgba(0,0,0,0.08);">
      <div class="flex items-center gap-4 px-6 pt-6 pb-5 border-b-2 border-gray-100 bg-gray-50">
        <img src="https://images.unsplash.com/photo-1558618666-fcd25c85cd64?w=200&q=80&auto=format&fit=crop" alt="" class="w-28 h-28 rounded-xl object-cover shadow-sm flex-shrink-0">
        <div class="flex-1 flex items-center justify-between">
          <h2 class="font-black text-gray-900 text-2xl">⚡ <%= e["titre"] %></h2>
          <% if e["urgence"] == "haute" %>
            <span style="background:#ef4444;color:#fff;" class="text-sm px-3 py-1.5 rounded-full font-bold">⚠️ Urgence réglementaire</span>
          <% end %>
        </div>
      </div>
      <div class="bg-white p-6">
        <div class="flex items-center gap-4 mb-5 flex-wrap">
          <span class="text-gray-700 text-sm font-semibold">DPE estimé :</span>
          <span style="background:<%= dpe_hex2[e['dpe_estime']] || '#9ca3af' %>;" class="px-4 py-1.5 rounded-lg text-white font-black text-xl"><%= e["dpe_estime"] %></span>
          <span class="text-gray-400 text-2xl">→</span>
          <span class="text-gray-700 text-sm font-semibold">Objectif :</span>
          <span style="background:<%= dpe_hex2[e['dpe_cible']] || '#9ca3af' %>;" class="px-4 py-1.5 rounded-lg text-white font-black text-xl"><%= e["dpe_cible"] %></span>
        </div>
        <p class="text-gray-800 text-lg leading-relaxed mb-5" style="font-size:1rem;line-height:1.75"><%= sentences_to_lines(e["analyse"]) %></p>
        <% if e["travaux"].present? %>
          <p class="text-xs font-bold text-gray-500 uppercase tracking-wider mb-3">Travaux prioritaires — cochez ceux que vous envisagez</p>
          <div class="space-y-2 mb-5" id="travaux-list">
            <% e["travaux"].sort_by{|t| t["priorite"].to_i}.each_with_index do |t, idx| %>
              <label class="flex items-center justify-between bg-gray-50 rounded-xl px-5 py-4 cursor-pointer hover:bg-emerald-50 transition-colors">
                <div class="flex items-center gap-4">
                  <input type="checkbox" class="travaux-cb w-5 h-5 accent-emerald-600 rounded flex-shrink-0"
                         data-min="<%= t['cout_min'] %>"
                         data-max="<%= t['cout_max'] %>"
                         data-gain="<%= t['gain_dpe'] %>"
                         checked
                         onchange="calcTravaux()">
                  <span class="w-8 h-8 rounded-full bg-emerald-100 text-emerald-800 text-sm font-black flex items-center justify-center"><%= t["priorite"] %></span>
                  <div>
                    <p class="text-base font-bold text-gray-900"><%= t["poste"] %></p>
                    <p class="text-sm text-emerald-700 font-semibold"><%= t["gain_dpe"] %></p>
                  </div>
                </div>
                <p class="text-base font-bold text-gray-900 ml-4 shrink-0"><%= number_to_currency(t["cout_min"], unit: "€", format: "%n %u", precision: 0, delimiter: " ") %> – <%= number_to_currency(t["cout_max"], unit: "€", format: "%n %u", precision: 0, delimiter: " ") %></p>
              </label>
            <% end %>
          </div>
          <div id="travaux-total" class="flex items-center justify-between rounded-xl px-5 py-4 text-white mb-6" style="background:#047857;">
            <div>
              <p class="text-base font-bold">Budget sélectionné</p>
              <p class="text-sm text-emerald-200" id="travaux-dpe-impact">—</p>
            </div>
            <p class="text-xl font-black" id="travaux-montant">—</p>
          </div>
          <script>
          function calcTravaux() {
            var cbs = document.querySelectorAll('.travaux-cb');
            var min = 0, max = 0;
            var gains = [];
            cbs.forEach(function(cb) {
              if (cb.checked) {
                min += parseInt(cb.dataset.min) || 0;
                max += parseInt(cb.dataset.max) || 0;
                if (cb.dataset.gain) gains.push(cb.dataset.gain);
              }
            });
            var fmt = function(x){ return x.toLocaleString('fr-FR') + ' €'; };
            document.getElementById('travaux-montant').textContent = fmt(min) + ' – ' + fmt(max);
            document.getElementById('travaux-dpe-impact').textContent = gains.length > 0
              ? 'Impact : ' + gains.join(', ')
              : 'Aucun travaux sélectionné';
            var total = document.getElementById('travaux-total');
            total.style.background = gains.length > 0 ? '#047857' : '#6b7280';
            var simSlider = document.getElementById('sim-montant');
            if (simSlider && max > 0) { simSlider.value = max; if (typeof calcPret === 'function') calcPret(); }
            if (typeof calcAides === 'function') calcAides();
          }
          document.addEventListener('DOMContentLoaded', calcTravaux);
          </script>
        <% end %>
<div class="border-t border-gray-100 pt-6 mb-6">
  <h3 class="font-bold text-gray-900 text-lg mb-4">💰 Aides mobilisables sur vos travaux</h3>
  <div class="mb-4">
