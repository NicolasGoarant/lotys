      <p style="font-size:0.8rem;color:#6b7280;line-height:1.6;margin:0 0 16px;">
        Renseignez quelques éléments — Lotys calcule vos mensualités, votre taux d'endettement et le coût total de votre crédit.
      </p>
      <button onclick="toggleSimulation()"
              style="display:block;width:100%;background:#059669;color:white;padding:12px;border-radius:12px;border:none;font-weight:700;font-size:0.875rem;cursor:pointer;margin-top:auto;">
        🧮 Lancer la simulation
      </button>
    </div>
  </div>

  <%# --- Formulaire de simulation (masqué par défaut) --- %>
  <div id="simulation-bancaire" style="display:none;background:white;border:2px solid #059669;border-radius:1.5rem;padding:2rem;margin-bottom:1.5rem;">
    <h3 style="font-size:1.1rem;font-weight:800;color:#111827;margin:0 0 4px;">🧮 Simulation de financement personnalisée</h3>
    <p style="font-size:0.8rem;color:#6b7280;margin:0 0 1.5rem;">Ces informations restent sur votre appareil et ne sont pas transmises à Lotys.</p>

    <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;margin-bottom:1rem;">
      <div>
        <label style="display:block;font-size:0.8rem;font-weight:600;color:#374151;margin-bottom:4px;">Ce que vous touchez chaque mois (nets)</label>
        <div style="display:flex;align-items:center;border:1px solid #e5e7eb;border-radius:10px;overflow:hidden;background:white;">
          <input type="number" id="sim-revenus" placeholder="ex : 2 800" min="0"
                 style="flex:1;padding:10px 12px;border:none;outline:none;font-size:0.875rem;"
                 oninput="calculerSimulation()">
          <span style="padding:10px 12px;background:#f9fafb;color:#9ca3af;font-size:0.8rem;">€/mois</span>
        </div>
      </div>
      <div>
        <label style="display:block;font-size:0.8rem;font-weight:600;color:#374151;margin-bottom:4px;">Crédits en cours (mensualités)</label>
        <div style="display:flex;align-items:center;border:1px solid #e5e7eb;border-radius:10px;overflow:hidden;background:white;">
          <input type="number" id="sim-charges" placeholder="ex : 400" min="0" value="0"
                 style="flex:1;padding:10px 12px;border:none;outline:none;font-size:0.875rem;"
                 oninput="calculerSimulation()">
          <span style="padding:10px 12px;background:#f9fafb;color:#9ca3af;font-size:0.8rem;">€/mois</span>
        </div>
      </div>
      <div>
        <label style="display:block;font-size:0.8rem;font-weight:600;color:#374151;margin-bottom:4px;">Apport disponible</label>
        <div style="display:flex;align-items:center;border:1px solid #e5e7eb;border-radius:10px;overflow:hidden;background:white;">
          <input type="number" id="sim-apport" placeholder="ex : 5 000" min="0" value="0"
                 style="flex:1;padding:10px 12px;border:none;outline:none;font-size:0.875rem;"
                 oninput="calculerSimulation()">
          <span style="padding:10px 12px;background:#f9fafb;color:#9ca3af;font-size:0.8rem;">€</span>
        </div>
      </div>
      <div>
        <label style="display:block;font-size:0.8rem;font-weight:600;color:#374151;margin-bottom:4px;">Votre âge</label>
        <div style="display:flex;align-items:center;border:1px solid #e5e7eb;border-radius:10px;overflow:hidden;background:white;">
          <input type="number" id="sim-age" placeholder="ex : 45" min="18" max="80"
                 style="flex:1;padding:10px 12px;border:none;outline:none;font-size:0.875rem;"
                 oninput="calculerSimulation()">
          <span style="padding:10px 12px;background:#f9fafb;color:#9ca3af;font-size:0.8rem;">ans</span>
        </div>
      </div>
    </div>

    <div style="margin-bottom:1rem;">
      <label style="display:block;font-size:0.8rem;font-weight:600;color:#374151;margin-bottom:4px;">Situation professionnelle</label>
      <select id="sim-situation" onchange="calculerSimulation()"
              style="width:100%;padding:10px 12px;border:1px solid #e5e7eb;border-radius:10px;font-size:0.875rem;background:white;">
        <option value="cdi">CDI / Fonctionnaire</option>
        <option value="independant">Indépendant / Professions libérales</option>
        <option value="retraite">Retraité</option>
      </select>
    </div>

    <%# Résultats %>
    <div id="sim-resultats" style="display:none;background:#f0fdf4;border:1px solid #bbf7d0;border-radius:1rem;padding:1.5rem;margin-top:1rem;">
      <h4 style="font-size:0.875rem;font-weight:700;color:#166534;margin:0 0 1rem;">📊 Résultats de votre simulation</h4>
      <div style="display:grid;grid-template-columns:repeat(2,1fr);gap:1rem;">
        <div style="background:white;border-radius:0.75rem;padding:1rem;text-align:center;">
          <p style="font-size:0.7rem;color:#6b7280;margin:0 0 4px;">Mensualité estimée</p>
          <p id="res-mensualite" style="font-size:1.5rem;font-weight:900;color:#059669;margin:0;">—</p>
          <p style="font-size:0.65rem;color:#9ca3af;margin:4px 0 0;">dont éco-PTZ à 0%</p>
        </div>
        <div style="background:white;border-radius:0.75rem;padding:1rem;text-align:center;">
          <p style="font-size:0.7rem;color:#6b7280;margin:0 0 4px;">Taux d'endettement</p>
          <p id="res-endettement" style="font-size:1.5rem;font-weight:900;margin:0;">—</p>
          <p id="res-endettement-label" style="font-size:0.65rem;margin:4px 0 0;">—</p>
        </div>
        <div style="background:white;border-radius:0.75rem;padding:1rem;text-align:center;">
          <p style="font-size:0.7rem;color:#6b7280;margin:0 0 4px;">Durée recommandée</p>
          <p id="res-duree" style="font-size:1.5rem;font-weight:900;color:#1e40af;margin:0;">—</p>
        </div>
        <div style="background:white;border-radius:0.75rem;padding:1rem;text-align:center;">
          <p style="font-size:0.7rem;color:#6b7280;margin:0 0 4px;">Coût total du crédit</p>
          <p id="res-cout" style="font-size:1.5rem;font-weight:900;color:#374151;margin:0;">—</p>
        </div>
      </div>
      <div id="res-alerte" style="display:none;margin-top:1rem;padding:12px;border-radius:0.75rem;font-size:0.8rem;"></div>
    </div>
  </div>

  <script>
    const RESTE = <%= reste_a_charge %>;
    const ECO_PTZ = <%= sim.eco_ptz_max_amount %>;

    function toggleSimulation() {
      const el = document.getElementById('simulation-bancaire');
      el.style.display = el.style.display === 'none' ? 'block' : 'none';
      if (el.style.display === 'block') el.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }

    function formatEur(n) {
      return new Intl.NumberFormat('fr-FR', { style: 'currency', currency: 'EUR', maximumFractionDigits: 0 }).format(n);
    }

    function mensualite(capital, tauxAnnuel, mois) {
      if (tauxAnnuel === 0) return capital / mois;
      const t = tauxAnnuel / 12;
      return capital * t / (1 - Math.pow(1 + t, -mois));
    }

    function calculerSimulation() {
      const revenus    = parseFloat(document.getElementById('sim-revenus').value) || 0;
      const charges    = parseFloat(document.getElementById('sim-charges').value) || 0;
      const apport     = parseFloat(document.getElementById('sim-apport').value) || 0;
      const age        = parseInt(document.getElementById('sim-age').value) || 0;
      const situation  = document.getElementById('sim-situation').value;

      if (revenus < 500 || age < 18) return;

      // Durée max selon âge (limite assurance 75 ans généralement)
      const dureeMax  = Math.min(Math.max(75 - age, 5), 20);
      const dureeReco = Math.min(dureeMax, 15);

      // Taux indicatif selon profil (approximation marché 2025)
      const taux = situation === 'cdi' ? 0.033 :
                   situation === 'independant' ? 0.037 : 0.038;

      // Capital à emprunter = reste à charge - apport - éco-PTZ
      const ecopty_eligible = Math.min(ECO_PTZ, RESTE);
      const capitalPret = Math.max(RESTE - apport - ecopty_eligible, 0);

      // Mensualités
      const mensEcoPtz  = mensualite(ecopty_eligible, 0, dureeReco * 12);
      const mensPret    = capitalPret > 0 ? mensualite(capitalPret, taux, dureeReco * 12) : 0;
      const mensTotal   = mensEcoPtz + mensPret;

      // Taux d'endettement
      const tauxEndet = ((charges + mensTotal) / revenus) * 100;

      // Coût total
      const coutTotal = mensPret * dureeReco * 12 - capitalPret;

      // Affichage
      document.getElementById('sim-resultats').style.display = 'block';
      document.getElementById('res-mensualite').textContent = formatEur(mensTotal) + '/mois';
      document.getElementById('res-duree').textContent = dureeReco + ' ans';
      document.getElementById('res-cout').textContent = coutTotal > 0 ? formatEur(coutTotal) : '0 €';

      const endetEl = document.getElementById('res-endettement');
      const endetLabel = document.getElementById('res-endettement-label');
      endetEl.textContent = tauxEndet.toFixed(1) + '%';

      if (tauxEndet <= 33) {
        endetEl.style.color = '#059669';
        endetLabel.textContent = '✓ Dans les normes bancaires';
        endetLabel.style.color = '#059669';
      } else if (tauxEndet <= 40) {
        endetEl.style.color = '#d97706';
        endetLabel.textContent = '⚠ Limite acceptable';
        endetLabel.style.color = '#d97706';
      } else {
        endetEl.style.color = '#dc2626';
        endetLabel.textContent = '✗ Au-dessus des normes';
        endetLabel.style.color = '#dc2626';
      }

      const alerte = document.getElementById('res-alerte');
      if (tauxEndet > 40) {
        alerte.style.display = 'block';
        alerte.style.background = '#fef2f2';
        alerte.style.border = '1px solid #fecaca';
        alerte.style.color = '#991b1b';
        alerte.innerHTML = '⚠️ Votre taux d\'endettement dépasse 40%. Un courtier peut parfois trouver des solutions adaptées (modulation de durée, différé de remboursement). Pensez aussi à vérifier si votre éco-PTZ couvre une part plus grande des travaux.';
      } else if (capitalPret === 0) {
        alerte.style.display = 'block';
        alerte.style.background = '#f0fdf4';
        alerte.style.border = '1px solid #bbf7d0';
        alerte.style.color = '#166534';
        alerte.innerHTML = '🎉 Bonne nouvelle : l\'éco-PTZ à 0% et votre apport couvrent l\'intégralité du reste à charge. Aucun emprunt complémentaire nécessaire.';
      } else {
        alerte.style.display = 'none';
      }
    }
  </script>


