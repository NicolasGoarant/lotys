<%# Header du bien %>
<div class="flex flex-col sm:flex-row sm:items-start sm:justify-between mb-8 gap-3">
  <div>
    <div class="flex items-center gap-3 mb-1">
      <h1 class="text-3xl font-bold text-gray-900"><%= @property.address %></h1>
      <span class="text-xs px-3 py-1 rounded-full font-semibold
        <%= @property.draft? ? 'bg-gray-100 text-gray-600' :
            @property.analyzing? ? 'bg-yellow-100 text-yellow-700' :
            @property.analyzed? ? 'bg-blue-100 text-blue-700' :
            'bg-emerald-100 text-emerald-700' %>">
        <%= @property.draft? ? '⏳ Brouillon' :
            @property.analyzing? ? '🔄 Analyse en cours' :
            @property.analyzed? ? '✅ Analysé' : '📢 Publié' %>
      </span>
    </div>
    <p class="text-gray-500"><%= @property.city %> <%= @property.zipcode %></p>
  </div>
  <div class="flex flex-col sm:flex-row gap-2 sm:mt-0">
    <%= link_to "Modifier", edit_property_path(@property), class: "text-center border border-gray-200 text-gray-600 px-4 py-2 rounded-xl text-sm hover:bg-gray-50 w-full sm:w-auto" %>
    <% if @property.draft? || @property.analyzed? %>
      <%= button_to "🔍 Lancer l'analyse IA", analyze_property_path(@property),
          class: "bg-blue-600 text-white px-4 py-2 rounded-xl text-sm hover:bg-blue-700 font-medium w-full sm:w-auto" %>
    <% end %>
    <% if @property.analyzed? %>
      <%= button_to "📢 Publier aux prestataires", publish_property_path(@property),
          class: "bg-emerald-600 text-white px-4 py-2 rounded-xl text-sm hover:bg-emerald-700 font-medium w-full sm:w-auto" %>
    <% end %>
  </div>
</div>

<%# Fiche identité %>
<% parsed_for_id = (@property.analysis&.content.present? ? (JSON.parse(@property.analysis.content) rescue nil) : nil) %>
<% val_from_ai = parsed_for_id&.dig("valeur") %>
<div class="bg-white rounded-2xl overflow-hidden mb-8 shadow-md" style="border:2px solid #e2e8f0; border-top:4px solid #475569;">
  <div class="flex items-center gap-4 px-6 pt-6 pb-5 border-b-2 border-gray-100 bg-gray-50">
    <img src="https://images.unsplash.com/photo-1560518883-ce09059eeffa?w=200&q=80&auto=format&fit=crop" alt="" class="w-28 h-28 rounded-xl object-cover shadow-sm flex-shrink-0">
    <div>
      <h2 class="font-black text-gray-900 text-2xl">📋 Identité du bien</h2>
      <p class="text-gray-500 text-sm"><%= @property.address %>, <%= @property.city %></p>
    </div>
  </div>
  <div class="p-6">
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 text-sm mb-3">
      <div class="bg-gray-50 rounded-xl p-4 text-center">
        <p class="text-gray-500 text-xs font-semibold uppercase tracking-wide mb-1">Type</p>
        <p class="font-bold text-gray-900 text-base"><%= @property.property_type&.capitalize || "—" %></p>
      </div>
      <div class="bg-gray-50 rounded-xl p-4 text-center">
        <p class="text-gray-500 text-xs font-semibold uppercase tracking-wide mb-1">Surface</p>
        <p class="font-bold text-gray-900 text-base"><%= @property.surface ? "#{@property.surface} m²" : "—" %></p>
      </div>
      <div class="bg-gray-50 rounded-xl p-4 text-center">
        <p class="text-gray-500 text-xs font-semibold uppercase tracking-wide mb-1">Construction</p>
        <p class="font-bold text-gray-900 text-base"><%= @property.construction_year || "—" %></p>
      </div>
      <div class="bg-gray-50 rounded-xl p-4 text-center">
        <p class="text-gray-500 text-xs font-semibold uppercase tracking-wide mb-1">Pièces</p>
        <p class="font-bold text-gray-900 text-base"><%= @property.nb_rooms || "—" %></p>
      </div>
      <div class="bg-gray-50 rounded-xl p-4 text-center">
        <p class="text-gray-500 text-xs font-semibold uppercase tracking-wide mb-1">Copropriété</p>
        <p class="font-bold text-gray-900 text-base"><%= @property.is_copropriete ? "Oui (#{@property.nb_lots} lots)" : "Non" %></p>
      </div>
      <div class="bg-gray-50 rounded-xl p-4 text-center">
        <p class="text-gray-500 text-xs font-semibold uppercase tracking-wide mb-1">DPE</p>
        <% dpe_val = @property.dpe_class || parsed_for_id&.dig("energie","dpe_estime") %>
        <% dpe_hex = {"A"=>"#16a34a","B"=>"#22c55e","C"=>"#84cc16","D"=>"#eab308","E"=>"#f97316","F"=>"#ea580c","G"=>"#dc2626"} %>
        <% if dpe_val %>
          <span style="background:<%= dpe_hex[dpe_val.upcase] || '#6b7280' %>;" class="inline-block px-3 py-1 rounded-lg text-white font-black text-lg"><%= dpe_val.upcase %></span>
        <% else %>
          <p class="font-bold text-gray-900 text-base">—</p>
        <% end %>
      </div>
      <div class="bg-gray-50 rounded-xl p-4 text-center">
        <p class="text-gray-500 text-xs font-semibold uppercase tracking-wide mb-1">Prix d'achat</p>
        <p class="font-bold text-gray-900 text-base"><%= val_from_ai&.dig("prix_acquisition") ? number_to_currency(val_from_ai["prix_acquisition"], unit: "€", format: "%n %u", precision: 0, delimiter: " ") : "—" %></p>
      </div>
      <div class="bg-gray-50 rounded-xl p-4 text-center">
        <p class="text-gray-500 text-xs font-semibold uppercase tracking-wide mb-1">Statut</p>
        <p class="font-bold text-gray-900 text-base"><%= @property.vacant? ? "Vacant" : "Occupé" %></p>
      </div>
    </div>
    <% if @property.description.present? %>
      <div class="bg-gray-50 rounded-xl p-4 mb-3">
        <p class="text-gray-500 text-xs font-semibold uppercase tracking-wide mb-1">Contexte</p>
        <p class="text-gray-800 text-base leading-relaxed"><%= @property.description %></p>
      </div>
    <% end %>
    <% dpe_display = @property.dpe_class || parsed_for_id&.dig("energie","dpe_estime") %>
    <% if dpe_display %>
      <% dpe_colors2 = { "A" => "#16a34a", "B" => "#22c55e", "C" => "#84cc16", "D" => "#eab308", "E" => "#f97316", "F" => "#ea580c", "G" => "#dc2626" } %>
      <% dpe_labels2 = { "A" => "Très performant", "B" => "Performant", "C" => "Assez performant", "D" => "Peu performant", "E" => "Énergivore", "F" => "Très énergivore", "G" => "Passoire thermique" } %>
      <div class="border-t border-gray-100 pt-4 mt-1">
        <p class="text-gray-500 text-xs font-semibold uppercase tracking-wide mb-3">⚡ Performance énergétique</p>
        <div class="flex items-center gap-4 flex-wrap">
          <div class="flex items-center justify-center rounded-xl text-white font-black text-4xl shadow-md"
               style="background:<%= dpe_colors2[dpe_display.upcase] || '#6b7280' %>; width:72px; height:72px;">
            <%= dpe_display.upcase %>
          </div>
          <div>
            <p class="text-lg font-bold text-gray-900"><%= dpe_labels2[dpe_display.upcase] %></p>
            <% if %w[F G].include?(dpe_display.upcase) %>
              <p class="text-sm text-red-600 mt-0.5 font-semibold">⚠️ Ce logement ne peut plus être mis en location.</p>
            <% elsif dpe_display.upcase == "E" %>
              <p class="text-sm text-orange-600 mt-0.5 font-semibold">⚠️ Interdiction de louer prévue en 2028.</p>
            <% end %>
          </div>
          <div class="flex gap-1 ml-auto">
            <% %w[A B C D E F G].each do |letter| %>
              <div style="background:<%= dpe_colors2[letter] %>; opacity:<%= letter == dpe_display.upcase ? '1' : '0.3' %>; width:32px; height:32px; border-radius:8px; display:flex; align-items:center; justify-content:center; font-weight:900; font-size:0.75rem; color:#fff;">
                <%= letter %>
              </div>
            <% end %>
          </div>
        </div>
      </div>
    <% end %>
  </div>
</div>

<%# Analyse IA %>
<% if @property.analysis&.content.present? %>
  <% parsed = (JSON.parse(@property.analysis.content) rescue nil) %>
  <% if parsed %>

    <% v = parsed["valeur"] %>
    <% if v %>
