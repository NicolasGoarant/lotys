<%= form_with(model: document, class: "contents") do |form| %>
  <% if document.errors.any? %>
    <div id="error_explanation" class="bg-red-50 text-red-500 px-3 py-2 font-medium rounded-md mt-3">
      <h2><%= pluralize(document.errors.count, "error") %> prohibited this document from being saved:</h2>

      <ul class="list-disc ml-6">
        <% document.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="my-5">
    <%= form.label :property_id %>
    <%= form.text_field :property_id, class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": document.errors[:property_id].none?, "border-red-400 focus:outline-red-600": document.errors[:property_id].any?}] %>
  </div>

  <div class="my-5">
    <%= form.label :document_type %>
    <%= form.number_field :document_type, class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": document.errors[:document_type].none?, "border-red-400 focus:outline-red-600": document.errors[:document_type].any?}] %>
  </div>

  <div class="my-5">
    <%= form.label :name %>
    <%= form.text_field :name, class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": document.errors[:name].none?, "border-red-400 focus:outline-red-600": document.errors[:name].any?}] %>
  </div>

  <div class="my-5">
    <%= form.label :ai_summary %>
    <%= form.text_area :ai_summary, rows: 4, class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": document.errors[:ai_summary].none?, "border-red-400 focus:outline-red-600": document.errors[:ai_summary].any?}] %>
  </div>

  <div class="my-5 flex items-center gap-2">
    <%= form.label :processed %>
    <%= form.check_box :processed, class: ["block shadow-sm rounded-md border order-first h-5 w-5", {"border-gray-400 focus:outline-blue-600": document.errors[:processed].none?, "border-red-400 focus:outline-red-600": document.errors[:processed].any?}] %>
  </div>

  <div class="inline">
    <%= form.submit class: "w-full sm:w-auto rounded-md px-3.5 py-2.5 bg-blue-600 hover:bg-blue-500 text-white inline-block font-medium cursor-pointer" %>
  </div>
<% end %>
