<div id="<%= dom_id document %>" class="w-full sm:w-auto my-5 space-y-5">
  <div>
    <strong class="block font-medium mb-1">Property:</strong>
    <%= document.property_id %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Document type:</strong>
    <%= document.document_type %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Name:</strong>
    <%= document.name %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Ai summary:</strong>
    <%= document.ai_summary %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Processed:</strong>
    <%= document.processed? ? "Yes" : "No" %>
  </div>
</div>
